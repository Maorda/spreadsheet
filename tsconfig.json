{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@spreadsheet/auth": [
        "libs/auth/src"
      ],
      "@spreadsheet/auth/*": [
        "libs/auth/src/*"
      ],
      "@spreadsheet/docs": [
        "libs/docs/src"
      ],
      "@spreadsheet/docs/*": [
        "libs/docs/src/*"
      ],
      "@spreadsheet/odm": [
        "libs/odm/src"
      ],
      "@spreadsheet/odm/*": [
        "libs/odm/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "libs/**/*",
    "apps/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}