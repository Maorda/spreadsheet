{
  "name": "spreadsheet",
  "version": "0.0.1",
  "packageManager": "npm@10.9.4",
  "description": "Monorepo para gestión de hojas de cálculo y automatización",
  "author": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo run build && nest build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start:dev": "concurrently -n \"libs,nest\" -c \"blue,green\" \"turbo run dev\" \"nest start --watch\"",
    "start:prod": "node dist/apps/spreadsheet/main"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "cache-manager": "^7.2.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.21",
    "googleapis": "^173.0.0",
    "nanoid": "^3.3.8",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@spreadsheet/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
      "^@spreadsheet/docs(|/.*)$": "<rootDir>/libs/docs/src/$1",
      "^@spreadsheet/odm(|/.*)$": "<rootDir>/libs/odm/src/$1"
    }
  }
}
