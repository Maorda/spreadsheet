        "axios": "^1.17.0",
        "cache-manager": "^7.2.8",
        "dayjs": "^1.11.21",
        "googleapis": "^173.0.0",
        "joi": "^18.2.3",
        "nanoid": "^5.1.11",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.2.2",
        "uuid": "^14.0.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.1.26",
        "@nestjs/core": "^11.1.26",
        "rxjs": "^7.8.2"
