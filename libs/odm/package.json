{
    "name": "@spreadsheet/odm",
    "version": "1.0.0",
    "description": "ODM para Google Sheets con NestJS - Núcleo de persistencia y mapeo relacional",
    "license": "MIT",
    "author": "Tu Nombre o Empresa <contacto@tudominio.com>",
    "keywords": [
        "nestjs",
        "google-sheets",
        "odm",
        "orm",
        "spreadsheet",
        "typescript",
        "database"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "axios": "^1.17.0",
        "cache-manager": "^7.2.8",
        "dayjs": "^1.11.21",
        "joi": "^18.2.3",
        "nanoid": "^3.3.8",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@spreadsheet/auth": "*",
        "googleapis": "^173.0.0",
        "pg": "^8.21.0",
        "@types/pg": "^8.20.0"
    },
    "peerDependencies": {
        "@nestjs/axios": "^3.0.0 || ^4.0.0",
        "@nestjs/cache-manager": "^2.0.0 || ^3.0.0",
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0",
        "@nestjs/platform-express": "^10.0.0 || ^11.0.0",
        "@spreadsheet/auth": "^1.0.0",
        "googleapis": "^173.0.0",
        "pg": "^8.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "class-validator": "^0.14.0",
        "class-transformer": "^0.5.1"
    }
}