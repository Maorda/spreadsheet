{
    "name": "@spreadsheet/docs",
    "version": "1.0.0",
    "description": "Librería para la gestión de Google Docs integrada con @spreadsheet/auth",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "axios": "^1.18.1",
        "docx": "^9.7.1",
        "docx-templates": "^4.13.0"
    },
    "devDependencies": {
        "@spreadsheet/auth": "*",
        "googleapis": "^173.0.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0",
        "@spreadsheet/auth": "^1.0.0",
        "googleapis": "^173.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "class-validator": "^0.14.0",
        "class-transformer": "^0.5.1"
    },
    "files": [
        "dist",
        "README.md",
        "dist/**/*",
        "src/assets/**/*"
    ],
    "publishConfig": {
        "access": "public"
    }
}