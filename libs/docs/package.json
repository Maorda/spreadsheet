{
    "name": "@spreadsheet/docs",
    "version": "1.0.0",
    "description": "Librería para manejo de docs y templates en Google Drive",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean --tsconfig tsconfig.lib.json",
        "dev": "tsup src/index.ts --format cjs,esm --watch --dts --tsconfig tsconfig.lib.json",
        "lint": "eslint src"
    },
    "dependencies": {
        "docx": "^8.5.0",
        "docx-templates": "^4.10.0",
        "googleapis": "^173.0.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0",
        "rxjs": "^7.8.0",
        "@spreadsheet/odm": "^1.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    }
}