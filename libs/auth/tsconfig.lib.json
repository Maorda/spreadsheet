{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    // Corregimos: Usar "Bundler" es el estándar moderno para librerías con tsup
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "strict": true,
    // Corregimos: Deshabilitamos incremental para que no choque con la generación de dts
    "incremental": false
  },
  "include": [
    "src/**/*"
  ]
}