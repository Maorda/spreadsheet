{
    "name": "@spreadsheet/auth",
    "version": "1.0.0",
    "description": "Librería de autenticación compartida para servicios de Google (Drive/Sheets/Script)",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean --tsconfig tsconfig.lib.json",
        "dev": "tsup src/index.ts --watch",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "googleapis": "^173.0.0"
    },
    "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    }
}