{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "docs": {
      "type": "library",
      "root": "libs/docs",
      "entryFile": "index",
      "sourceRoot": "libs/docs/src",
      "compilerOptions": {
        "tsConfigPath": "libs/docs/tsconfig.lib.json"
      }
    },
    "odm": {
      "type": "library",
      "root": "libs/odm",
      "entryFile": "index",
      "sourceRoot": "libs/odm/src",
      "compilerOptions": {
        "tsConfigPath": "libs/odm/tsconfig.lib.json"
      }
    }
  }
}