{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "docs": {
      "type": "library",
      "root": "libs/docs",
      "entryFile": "index",
      "sourceRoot": "libs/docs/src",
      "compilerOptions": {
        "tsConfigPath": "libs/docs/tsconfig.lib.json",
        "assets": [
          {
            "include": "assets/**/*",
            "outDir": "dist/libs/docs/src",
            "watchAssets": true
          }
        ]
      }
    },
    "odm": {
      "type": "library",
      "root": "libs/odm",
      "entryFile": "index",
      "sourceRoot": "libs/odm/src",
      "compilerOptions": {
        "tsConfigPath": "libs/odm/tsconfig.lib.json"
      }
    }
  }
}